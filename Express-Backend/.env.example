# Server Configuration
PORT=5000
NODE_ENV=development

# Google Cloud Platform
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_BUCKET_NAME=video-messaging-app-storage
GOOGLE_CLOUD_KEY_FILE=./gcp-key.json
# For production (Railway), use this instead of GOOGLE_CLOUD_KEY_FILE:
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# AI Services
GEMINI_API_KEY=your-gemini-api-key

# CORS Origins
ELECTRON_HOST=http://localhost:5173
NEXT_API_HOST=http://localhost:3000

# Production URLs (update after deployment)
# NEXT_API_HOST=https://your-website.vercel.app
# WEBSITE_URL=https://your-website.vercel.app
